---
import { Icon } from "astro-icon/components";

const knownProviders: Record<
  string,
  { name: string; prefix: string; icon: string; color: string }
> = {
  email: {
    name: "Email",
    prefix: "mailto:",
    icon: "simple-icons:protonmail",
    color: "var(--gray-12)",
  },
  github: {
    name: "GitHub",
    prefix: "https://github.com/",
    icon: "simple-icons:github",
    color: "var(--gray-11)",
  },
  linkedin: {
    name: "LinkedIn",
    prefix: "https://linkedin.com/in/",
    icon: "simple-icons:linkedin",
    color: "var(--gray-11)",
  },
};

export type Props = { links: Record<string, string> };
const links = Object.entries(Astro.props.links).map(([key, value]) => {
  const provider = knownProviders[key];
  if (provider) {
    return {
      name: provider.name,
      icon: provider.icon,
      color: provider.color,
      url: `${provider.prefix}${value}`,
    };
  }
  return {
    name: key,
    color: "var(--gray-12)",
    icon: "material-symbols:arrow-outward",
    url: value,
  };
});
---

<div class="flex flex-row flex-wrap gap-x-2.5">
  {links.map((link) => (
    <a href={link.url} aria-label={link.name} class="hover:text-green-11 transition-colors">
      <Icon name={link.icon} style={`color: ${link.color}`} />
    </a>
  ))}
</div>
