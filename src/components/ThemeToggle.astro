---
import { Icon } from "astro-icon/components";
---

<button
  id="theme-toggle"
  class="inline-flex items-center justify-center h-6 w-6 text-gray-11 hover:text-green-11 transition-colors"
  aria-label="Toggle theme"
>
  <Icon name="material-symbols:light-mode" class="dark:hidden" />
  <Icon name="material-symbols:dark-mode" class="hidden dark:inline" />
</button>

<script>
  const btn = document.getElementById("theme-toggle");
  if (btn) {
    btn.addEventListener("click", () => {
      const html = document.documentElement;
      const isDark = html.classList.toggle("dark");
      html.classList.toggle("light", !isDark);
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  }
</script>
